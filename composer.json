{
  "name": "coringawc/filament-tutorials",
  "description": "Filament plugin for interactive panel tutorials powered by Driver.js and stable targets.",
  "keywords": [
    "coringawc",
    "laravel",
    "filament",
    "filament-plugin",
    "tutorials",
    "onboarding",
    "driverjs"
  ],
  "homepage": "https://github.com/CoringaWc/filament-tutorials",
  "support": {
    "issues": "https://github.com/CoringaWc/filament-tutorials/issues",
    "source": "https://github.com/CoringaWc/filament-tutorials"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Argemiro Dias",
      "email": "argemirodiaseng@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "filament/filament": "^5.0",
    "spatie/laravel-package-tools": "^1.15"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "laravel/boost": "^2.4",
    "laravel/pint": "^1.0",
    "nunomaduro/collision": "^8.9",
    "orchestra/testbench": "^11.0",
    "orchestra/workbench": "^11.0",
    "pestphp/pest": "^4.6",
    "pestphp/pest-plugin-browser": "^4.3",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpunit/phpunit": "^12.0",
    "rector/rector": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "CoringaWc\\FilamentTutorials\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CoringaWc\\FilamentTutorials\\Tests\\": "tests/",
      "Workbench\\App\\": "workbench/app/",
      "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@clear",
      "@prepare"
    ],
    "analyse": "phpstan analyse --memory-limit=1G",
    "lint": "pint",
    "refactor": "rector",
    "test": "pest",
    "test:types": "phpstan analyse --memory-limit=1G",
    "test:refactor": "rector --dry-run",
    "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "build": [
      "@php vendor/bin/testbench workbench:build --ansi",
      "@php vendor/bin/testbench filament:assets --ansi"
    ],
    "bootstrap:workbench": [
      "@build",
      "@fresh:workbench"
    ],
    "seed:workbench": "@php vendor/bin/testbench db:seed --class=Workbench\\\\Database\\\\Seeders\\\\DatabaseSeeder --ansi --no-interaction",
    "fresh:workbench": "@php vendor/bin/testbench migrate:fresh --seed --seeder=Workbench\\\\Database\\\\Seeders\\\\DatabaseSeeder --ansi --no-interaction",
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "@bootstrap:workbench",
      "@php vendor/bin/testbench serve --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "CoringaWc\\FilamentTutorials\\FilamentTutorialsServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
